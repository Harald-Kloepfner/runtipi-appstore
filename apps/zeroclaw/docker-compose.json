{
  "services": {
    "zeroclaw": {
      "image": "ghcr.io/zeroclaw-labs/zeroclaw:latest",
      "restart": "unless-stopped",
      "environment": {
        "API_KEY": "${API_KEY}",
        "PROVIDER": "${PROVIDER:-openrouter}",
        "ZEROCLAW_ALLOW_PUBLIC_BIND": "true",
        "ZEROCLAW_GATEWAY_PORT": "42617"
      },
      "volumes": [
        "${APP_DATA_DIR}/data:/zeroclaw-data"
      ],
      "x-runtipi": {
        "is_main": true,
        "internal_port": "42617"
      },
      "healthcheck": {
        "test": [
          "CMD",
          "zeroclaw",
          "status",
          "--format=exit-code"
        ],
        "interval": "60s",
        "timeout": "10s",
        "retries": 3,
        "start_period": "10s"
      }
    }
  },
  "x-runtipi": {
    "schema_version": 2
  }
}
